<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.ReparaHogar" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_medium</item>
        <item name="colorSecondary">@color/highlight</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="android:colorBackground">@color/surface_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="Theme.ReparaHogar" parent="Base.Theme.ReparaHogar" />

    <style name="Theme.App" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_accent</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedImage8dp">
        <item name="cornerSize">8dp</item>
    </style>

    <!-- Estilo para cards elevadas -->
    <style name="CardElevada" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">8dp</item>
        <item name="cardCornerRadius">20dp</item>
    </style>
</resources>