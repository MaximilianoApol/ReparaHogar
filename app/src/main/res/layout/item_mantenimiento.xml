<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_card"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Indicador lateral de color -->
        <View
            android:id="@+id/indicadorEstado"
            android:layout_width="5dp"
            android:layout_height="52dp"
            android:background="@color/estado_pendiente"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plomería"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/txtDescripcion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reparación de fuga"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/lblStatusDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDIENTE · 13-03-2026"
                android:textSize="11sp"
                android:textColor="@color/estado_pendiente"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="180"
            app:tint="@color/text_hint"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>