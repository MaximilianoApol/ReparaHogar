<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/surface_card"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Indicador de color lateral -->
        <View
            android:id="@+id/indicadorEstado"
            android:layout_width="5dp"
            android:layout_height="56dp"
            android:background="#F59E0B"
            android:layout_marginEnd="14dp"/>

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plomería"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/txtDescripcion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reparación de fuga"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/lblStatusDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDIENTE · 13-03-2026"
                android:textSize="11sp"
                android:textColor="@color/estado_pendiente"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- Flecha -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="180"
            app:tint="@color/text_hint"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>