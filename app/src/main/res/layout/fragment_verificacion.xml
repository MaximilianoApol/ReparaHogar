<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarVerificacion"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#00468B"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Verificación de identidad"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </com.google.android.material.appbar.MaterialToolbar>

    <FrameLayout
        android:id="@+id/containerSelfie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarVerificacion">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgSelfie"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="#E1D5F5"
            android:padding="40dp"
            android:src="@drawable/ic_add"
            app:shapeAppearanceOverlay="@style/CircleImage" />

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/ic_check_circle_green" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Tomar selfie"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@id/containerSelfie"
        app:layout_constraintStart_toStartOf="@id/containerSelfie"
        app:layout_constraintTop_toBottomOf="@id/containerSelfie" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubirINE"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:backgroundTint="#F2F2F2"
        android:text="Subir foto de INE"
        android:textAllCaps="false"
        android:textColor="@color/black"
        app:cornerRadius="20dp"
        app:icon="@drawable/ic_attach_file"
        app:iconTint="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="32dp"
        app:layout_constraintTop_toBottomOf="@id/containerSelfie" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutSelectorServicios"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="24dp"
        android:hint="Tipo de servicio"
        app:layout_constraintTop_toBottomOf="@id/btnSubirINE">

        <AutoCompleteTextView
            android:id="@+id/spinnerServicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:cursorVisible="false"
            android:focusable="false"
            android:clickable="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkPermisoUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="32dp"
        android:text="Permitir acceso a mi ubicación en tiempo real para aparecer en las búsquedas de clientes cercanos."
        android:textColor="#666666"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/layoutSelectorServicios" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnviarVerificacion"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="40dp"
        android:backgroundTint="#00468B"
        android:enabled="false"
        android:text="Enviar para verificación"
        android:textAllCaps="false"
        app:cornerRadius="28dp"
        app:icon="@drawable/ic_send"
        app:layout_constraintBottom_toBottomOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>